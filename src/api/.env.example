# BenchGoblins API Environment Variables

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# ESPN Fantasy API (optional)
ESPN_API_KEY=

# Database
DATABASE_URL=postgresql://localhost:5432/benchgoblins

# Redis Cache
REDIS_URL=redis://localhost:6379

# App Settings
DEBUG=true
LOG_LEVEL=info
ENVIRONMENT=development

# Admin API Key (required in production)
# Protects admin endpoints: cache, budget, notifications, metrics
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# ============================================
# Google OAuth (Required for user sign-in)
# ============================================
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized JavaScript origins: http://localhost:3001
# 3. Add authorized redirect URIs: http://localhost:3001
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JWT Secret for session tokens (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-secret-key-min-32-characters-long

# ============================================
# Stripe Billing (Required for monetization)
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Create a webhook endpoint in Stripe dashboard:
# URL: https://your-domain.com/billing/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# Create a Price in Stripe for Pro subscription ($9.99/month)
# Get the price ID from: https://dashboard.stripe.com/prices
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
