# BenchGoblins Web Configuration

# API URL - leave empty for development (uses Next.js rewrite to localhost:8000)
# Set to your production API URL in production
NEXT_PUBLIC_API_URL=http://localhost:8000

# App URL - for OAuth redirect URIs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (required for Google Sign-In)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Make sure to add your domain to the authorized JavaScript origins
# and your callback URL to authorized redirect URIs
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend OAuth credentials (used by API server)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
