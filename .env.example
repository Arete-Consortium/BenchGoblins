# BenchGoblins Environment Variables
# Copy this to .env and fill in your values

# Required: Anthropic API key for Claude integration
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL password (default: benchgoblins)
POSTGRES_PASSWORD=benchgoblins

# Database URL (auto-configured in docker-compose)
DATABASE_URL=postgresql://benchgoblins:benchgoblins@postgres:5432/benchgoblins

# Redis URL (auto-configured in docker-compose)
REDIS_URL=redis://redis:6379

# Logging level: debug, info, warning, error
LOG_LEVEL=info

# Sentry error monitoring (optional)
# Get your DSN from https://sentry.io
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Environment name for Sentry
ENVIRONMENT=development

# Yahoo Fantasy OAuth (optional)
# Register app at https://developer.yahoo.com/apps/
# YAHOO_CLIENT_ID=your_client_id
# YAHOO_CLIENT_SECRET=your_client_secret
