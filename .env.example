# GameSpace Environment Variables
# Copy this to .env and fill in your values

# Required: Anthropic API key for Claude integration
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL password (default: gamespace)
POSTGRES_PASSWORD=gamespace

# Database URL (auto-configured in docker-compose)
DATABASE_URL=postgresql://gamespace:gamespace@postgres:5432/gamespace

# Redis URL (auto-configured in docker-compose)
REDIS_URL=redis://redis:6379

# Logging level: debug, info, warning, error
LOG_LEVEL=info

# Sentry error monitoring (optional)
# Get your DSN from https://sentry.io
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Environment name for Sentry
ENVIRONMENT=development
