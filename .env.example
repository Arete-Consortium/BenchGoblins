# GameSpace Environment Variables
# Copy this to .env and fill in your values

# Required: Anthropic API key for Claude integration
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Database (uncomment postgres in docker-compose.yml)
# DATABASE_URL=postgresql://gamespace:gamespace@postgres:5432/gamespace

# Optional: Redis cache (uncomment redis in docker-compose.yml)
# REDIS_URL=redis://redis:6379

# Logging
LOG_LEVEL=info
